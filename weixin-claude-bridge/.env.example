# 复制这个文件为 .env，填你自己的值
# cp .env.example .env

# ── 主 API 配置（必填，处理文字消息）──
API_PROVIDER=deepseek
API_KEY=sk-your-key-here
API_MODEL=deepseek-chat

# 可选：换其他兼容 API
# API_PROVIDER=openai
# API_KEY=sk-xxx
# API_BASE_URL=https://api.openai.com
# API_MODEL=gpt-4o

# ── 视觉 API 配置（可选，处理图片消息）──
# 不配则用主 API（如主 API 不支持 vision，图片会回复"不支持"）
# VISION_API_PROVIDER=openai
# VISION_API_KEY=sk-xxx
# VISION_API_MODEL=gpt-4o
# VISION_API_BASE_URL=https://api.openai.com

# ── 系统提示词文件（热加载，改文件即生效，无需重启）──
SYSTEM_PROMPT_FILE=./system_prompt.md
# 切换 xaj：SYSTEM_PROMPT_FILE=./system_prompt_xaj.md

# ── 主动消息（可选，让 AI 定时主动找你聊天）──
# PROACTIVE_ENABLED=true
# PROACTIVE_TARGET=你的微信备注名或昵称
# PROACTIVE_MIN=90              # 最短间隔（分钟）
# PROACTIVE_MAX=360             # 最长间隔（分钟），三角分布不固定
# PROACTIVE_COOLDOWN=15         # 你回复后冷却（分钟）
# QUIET_START=23                # 夜间免打扰开始（时）
# QUIET_END=8                   # 夜间免打扰结束（时）
